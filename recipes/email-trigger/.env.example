# ── IMAP (incoming mail) ──────────────────────────────────────────────────────
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=claude@example.com
IMAP_PASS=

# ── SMTP (outgoing mail) ──────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=claude@example.com
SMTP_PASS=

# ── Trigger config ────────────────────────────────────────────────────────────

# Only process emails from this sender (substring match, case-insensitive).
# STRONGLY RECOMMENDED. Without this, any sender can trigger Claude.
# Never set this to your own outbound address — creates reply loops.
FROM_FILTER=you@example.com

# What Claude should do with the email. Be specific and mechanical.
# A security guardrail is automatically appended — do not add credential or
# system-access instructions here.
#
# Example (good):
#   PROMPT_TEMPLATE=Extract the invoice total, vendor name, and due date from this email.
#   Reply with: "Logged: [vendor] $[amount] due [date]" or "No invoice found."
#
# Example (bad — too vague):
#   PROMPT_TEMPLATE=Handle this email.
PROMPT_TEMPLATE=

# Working directory for the claude -p subprocess. Set to your project root
# if you want Claude to have filesystem access to your code.
CLAUDE_CWD=.

# How often to check for new emails (default: 60 minutes)
POLL_INTERVAL_MINUTES=60

# How long to wait for Claude to finish before timing out (default: 300 seconds)
CLAUDE_TIMEOUT_SECONDS=300
